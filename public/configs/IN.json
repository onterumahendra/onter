{
  "countryCode": "IN",
  "countryName": "India",
  "currency": "INR",
  "currencySymbol": "₹",
  "formSections": [
    {
      "section": "Personal Details",
      "type": "simple",
      "description": "Please provide your personal identification details",
      "fields": [
        {
          "label": "PAN",
          "name": "pan",
          "type": "text",
          "placeholder": "e.g., ABCDE1234F",
          "validation": {
            "required": true,
            "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]{1}$",
            "errorMessage": "PAN must be in format: ABCDE1234F (5 letters, 4 digits, 1 letter)"
          }
        },
        {
          "label": "UID No. (Aadhaar Card)",
          "name": "aadhaar",
          "type": "text",
          "placeholder": "12 digit number",
          "validation": {
            "pattern": "^[0-9]{12}$",
            "errorMessage": "Aadhaar must be exactly 12 digits"
          }
        },
        {
          "label": "Ration Card No.",
          "name": "ration_card_no",
          "type": "text",
          "placeholder": "Enter ration card number"
        },
        {
          "label": "Blood Group",
          "name": "blood_group",
          "type": "select",
          "options": [
            "A+",
            "A-",
            "B+",
            "B-",
            "AB+",
            "AB-",
            "O+",
            "O-"
          ],
          "placeholder": "Select blood group"
        },
        {
          "label": "Passport No.",
          "name": "passport_no",
          "type": "text",
          "placeholder": "e.g., A1234567",
          "validation": {
            "pattern": "^[A-Z][0-9]{7}$",
            "errorMessage": "Passport number format: 1 letter followed by 7 digits"
          }
        },
        {
          "label": "Driving License No.",
          "name": "driving_license_no",
          "type": "text",
          "placeholder": "Enter driving license number"
        },
        {
          "label": "Voters ID Card No.",
          "name": "voters_id_no",
          "type": "text",
          "placeholder": "Enter voter ID"
        },
        {
          "label": "EPF Account No. / UAN",
          "name": "epf_uan_no",
          "type": "text",
          "placeholder": "12 digit UAN",
          "validation": {
            "pattern": "^[0-9]{12}$",
            "errorMessage": "UAN must be 12 digits"
          }
        },
        {
          "label": "PPF Account No.",
          "name": "ppf_no",
          "type": "text",
          "placeholder": "Enter PPF account number"
        },
        {
          "label": "Telephone/Mobile No.",
          "name": "telephone_mobile",
          "type": "text",
          "placeholder": "10 digit mobile number",
          "validation": {
            "required": true,
            "pattern": "^[0-9]{10}$",
            "errorMessage": "Mobile number must be exactly 10 digits"
          }
        },
        {
          "label": "Mobile Service Provider",
          "name": "mobile_service_provider",
          "type": "text",
          "placeholder": "e.g., Airtel, Jio, Vi, BSNL"
        },
        {
          "label": "Gas Consumer No.",
          "name": "gas_consumer_no",
          "type": "text",
          "placeholder": "Enter gas consumer number"
        },
        {
          "label": "Gas Service Provider",
          "name": "gas_service_provider",
          "type": "text",
          "placeholder": "e.g., Indane, HP Gas, Bharat Gas"
        },
        {
          "label": "Electricity Account No.",
          "name": "electricity_account_no",
          "type": "text",
          "placeholder": "Enter electricity account number"
        },
        {
          "label": "Electricity Service Provider",
          "name": "electricity_service_provider",
          "type": "text",
          "placeholder": "Enter provider name"
        },
        {
          "label": "Water Account No.",
          "name": "water_account_no",
          "type": "text",
          "placeholder": "Enter water account number"
        }
      ]
    },
    {
      "section": "Emergency contact details",
